import math
n = int(input())

def is_prime(num):
    if num < 2:
        return False

    for i in range(2, int(math.sqrt(num)) + 1):
        if num % i == 0:
            return False

    return True

rev = int(str(n)[::-1])

if is_prime(n) and is_prime(rev):
    print("Twisted Prime")
else:
    print("Not Twisted Prime")